<!-- 
    ID 100400 - это правила для обнаружения потенциально нежелатеьлного ипсользования Remote Desktop
    Правила предварительно будут располагаться в диапазоне 100400..100499 
-->


<group name="windows, windows_securit, remote_access, test, needs">
    <rule id="100400" level="4">

        <!--match>8001|TERMSRV</match-->
        <field name="win.system.eventID">8001</field>
        <field name="win.eventdata.targetname">^TERMSRV</field>
        <description>Potential Remote Desktop Connection to Non-Domain Host</description>
        <info type="link">https://github.com/SigmaHQ/sigma/blob/1e029b98cf74a679bcd02e8f428c43252615bdb0/rules/windows/builtin/win_susp_ntlm_rdp.yml</info>
        <group>attack.command_and_control, </group>
        
    </rule>

    <rule id="100401" level="3">

        <field name="win.system.EventID">4624</field>
        <field name="win.eventdata.logonType">10</field>
        <field name="win.eventdata.authenticationPackageName">Negotiate</field>
        <match>"accountName":"Admin-"</match>
        <!--field name="win.system.AccountName">^Admin-</field-->

        <description>Admin User Remote Logon</description>

        <mitre>
            <id>T1078</id>
            <id>T1078.001</id>
            <id>T1078.002</id>
            <id>T1078.003</id>
        </mitre>

        <info type="link">https://github.com/SigmaHQ/sigma/blob/1e029b98cf74a679bcd02e8f428c43252615bdb0/rules/windows/builtin/win_admin_rdp_login.yml</info>

        <group>attack.lateral_movement, car.2016-04-005</group>
    </rule>

    <rule id="100402" level="7">

        <field name="win.system.eventID">7045</field>
        <match>"ServiceName":"srservice"|</match>>
        <match>"ServiceName":"ipvpn"|</match>
        <match>"ServiceName":"hkmsvc"|</match>
        <!--field name="win.eventdata.ServiceName">srservice|ipvpn|hkmsvc</field-->

        <description>Turla Service Install</description>

        <mitre>
            <id>T1050</id>
            <id>T1543.003</id>
        </mitre>

        <info type="text">This rule detects a service install of malicious services mentioned in Carbon Paper - Turla report by ESET</info>
        <info type="link">https://github.com/SigmaHQ/sigma/blob/master/rules/windows/builtin/win_apt_carbonpaper_turla.yml</info>
        <group>attack.persistence</group>
    </rule>

    <rule id="100403" level="4">

        <field name="win.system.eventID">4825</field>

        <description>Denied Access To Remote Desktop</description>

        <mitre>
            <id>T1076</id>
            <id>T1021.001</id>
        </mitre>

        <info type="text">This event is generated when an authenticated user who is not allowed to log on remotely attempts to connect to this computer through Remote Desktop.
        Often, this event can be generated by attackers when searching for available windows servers in the network.</info>
        
        <info type="link">https://github.com/SigmaHQ/sigma/blob/a08571be9107d1c0e216400ffbb89c394fcd2570/rules/windows/builtin/win_not_allowed_rdp_access.yml</info>
        <group>attack.lateral_movement</group>
    </rule>

    <rule id="100404" level="12">

        <info type="text">Detects the use of a scanner by zerosum0x0 that discovers targets vulnerable to  CVE-2019-0708 RDP RCE aka BlueKeep</info>

        <field name="win.system.eventID">4625</field>
        <match>"accountName":"AAAAAAA"</match>
        <!--field name="win.eventdata.AccountName">AAAAAAA</field-->

        <description>Scanner PoC for CVE-2019-0708 RDP RCE Vuln</description>

        <mitre>
            <id>T1210</id>
        </mitre>

        <info type="link">https://github.com/SigmaHQ/sigma/blob/a08571be9107d1c0e216400ffbb89c394fcd2570/rules/windows/builtin/win_rdp_bluekeep_poc_scanner.yml</info>
        <group>attack.lateral_movement, car.2013-07-002</group>
    </rule>

    <rule id="100405" level="7">

        <info type="text">RDP login with localhost source address may be a tunnelled login</info>

        <field name="win.system.eventID">4624</field>
        <field name="win.eventdata.logonType">10</field>
        <field name="win.eventdata.sourceIp">127.0.0.1</field>

        <description>RDP Login from Localhost</description>

        <mitre>
            <id>T1076</id>
            <id>T1021.001</id>
        </mitre>

        <info type="link">https://github.com/SigmaHQ/sigma/blob/a08571be9107d1c0e216400ffbb89c394fcd2570/rules/windows/builtin/win_rdp_localhost_login.yml</info>
        <group>attack.lateral_movement, car.2013-07-002</group>
    </rule>
</group>
