    <mitre>
      <id>T1040</id>
    </mitre>
    <group>attack.credential_access, attack.discovery, metron, win014,</group>
  </rule>
  
  <rule id="100110" level="6">
    <if_sid>100100, 61603</if_sid>
    <field name="win.eventdata.commandLine">reg</field>
    <field name="win.eventdata.commandLine"> \s*add \s*</field>
    <field name="win.eventdata.commandLine">\\Services\\VSS\\Diag</field>
    <field name="win.eventdata.commandLine">/d \s*Disabled</field>
    <description>Disabled Volume Snapshots $(win.eventdata.commandLine)</description>
    <info type="text">Detects commands that temporarily turn off Volume Snapshots. </info>
    <info type="link">https://github.com/SigmaHQ/sigma/blob/a08571be9107d1c0e216400ffbb89c394fcd2570/rules/windows/process_creation/win_susp_volsnap_disable.yml</info>
    <mitre>
      <id>T1562</id>
      <id>T1562.001</id>
    </mitre>
    <group>attack.defense_evasion, metron, win018,</group>
  </rule>
  
  <rule id="100111" level="6">
    <if_group>process_creation_4688</if_group>
    <field name="win.eventdata.newProcessName">\\auditpol.exe$</field>
    <field name="win.eventdata.commandLine">disable|clear|remove|restore</field>
    <description>Suspicious Auditpol Usage $(win.eventdata.commandLine)</description>
    <info type="text">Threat actors can use auditpol binary to change audit policy configuration to impair detection capability. </info>
    <info type="text">This can be carried out by selectively disabling/removing certain audit policies as well as restoring a custom policy owned by the threat actor. </info>
    <info type="link">https://github.com/SigmaHQ/sigma/blob/a08571be9107d1c0e216400ffbb89c394fcd2570/rules/windows/process_creation/win_sus_auditpol_usage.yml</info>
    <mitre>
      <id>T1562</id>
      <id>T1562.002</id>
    </mitre>
    <group>attack.defense_evasion, attack.discovery, metron, win019,</group>
  </rule>
  
  <rule id="100112" level="6"> <!-- дублирование правила для Sysmon -->
    <if_group>sysmon_event1</if_group> 
    <field name="win.eventdata.image">\\auditpol.exe$</field>
    <field name="win.eventdata.commandLine">disable|clear|remove|restore</field>
    <description>Suspicious Auditpol Usage $(win.eventdata.commandLine)</description>
    <info type="text">Threat actors can use auditpol binary to change audit policy configuration to impair detection capability. </info>
    <info type="text">This can be carried out by selectively disabling/removing certain audit policies as well as restoring a custom policy owned by the threat actor. </info>
    <info type="link">https://github.com/SigmaHQ/sigma/blob/a08571be9107d1c0e216400ffbb89c394fcd2570/rules/windows/process_creation/win_sus_auditpol_usage.yml</info>
