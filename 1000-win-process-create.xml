      <id>T1562</id>
      <id>T1562.002</id>
    </mitre>
    <group>attack.defense_evasion, attack.discovery, metron, win019,</group>
  </rule>
  
  <rule id="100113" level="6">
    <if_sid>100100, 61603</if_sid>
    <field name="win.eventdata.commandLine">(netsh \s*firewall \s*set \s*opmode \s*mode=disable)|(netsh \s*advfirewall \s*set \.* \s*state \s*off)</field>
    <description>Firewall Disabled via Netsh</description>
    <info type="text">Detects netsh commands that turns off the Windows firewall. </info>
    <info type="link">https://github.com/SigmaHQ/sigma/blob/a08571be9107d1c0e216400ffbb89c394fcd2570/rules/windows/process_creation/win_susp_firewall_disable.yml</info>
