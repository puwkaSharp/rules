      <id>S0108</id>
    </mitre>
    <group>attack.defense_evasion, metron, win020,</group>
  </rule>
  
  <rule id="100114" level="6">
    <if_sid>100100, 61603</if_sid>
    <field name="win.eventdata.commandLine">logman \s*stop \s*EventLog-System</field>
    <description>Disable Windows Eventlog</description>
    <info type="text">Detects command that is used to disable Windows eventlog. </info>
