  </rule>
  
  <rule id="100115" level="6">
    <if_sid>100100, 61603</if_sid>
    <field name="win.eventdata.commandLine">wmic</field>
    <field name="win.eventdata.commandLine">product \s*where \s*name=</field>
    <field name="win.eventdata.commandLine">call \s*uninstall</field>
    <field name="win.eventdata.commandLine">/nointeractive</field>
    <field name="win.eventdata.commandLine">Antivirus|Endpoint Security|Endpoint Detection|Crowdstrike Sensor|Windows Defender|VirusScan|Threat Protection|Endpoint Sensor</field>
    <description>Wmic Uninstall Security Product</description>
    <info type="text">DetDetects deinstallation of security products using WMIC utility. </info>
    <info type="link">https://github.com/SigmaHQ/sigma/blob/08ca62cc8860f4660e945805d0dd615ce75258c1/rules/windows/process_creation/win_susp_wmic_security_product_uninstall.yml</info>
    <mitre>
      <id>T1562</id>
      <id>T1562.001</id>
    </mitre>
    <group>attack.defense_evasion, metron, win022,</group>
  </rule>
  
