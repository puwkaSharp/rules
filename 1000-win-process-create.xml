    60000 Group of windows rules 
    60001 Group of Windows rules for the Security channel
    60103 Windows audit success event
    100100 Process creation group (custom) 

    ID 100100 - это правила для обнаружения создания процесса
    Правила предварительно будут располагаться в диапазоне 100101..100299 
-->

<!--
    Похоже, придётся использовать два правила на каждое сигма-правило, 
    потому что поля событий 4688 и 1 называются по разному и
    проверять поля по ИЛИ вроде нельзя
-->

<var name="PROC_FREQ">4</var> <!-- Значение по умолчанию количества событий за промежуток времент для сработки -->

<group name="windows,windows_security,process_creation,">

  <rule id="100100" level="3">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4688$</field>
    <description>Process creation</description>
    <options>no_full_log</options>
    <group>process_creation_4688</group>
  </rule>
    
  <!-- 100101 свободно -->
  
  <rule id="100102" level="6">
    <if_group>process_creation_4688</if_group>
    <field name="win.eventdata.newProcessName">\\schtasks.exe$</field>
    <field name="win.eventdata.commandLine"> /create </field>
    <description>Scheduled Task Creation by $(win.eventdata.parentProcessName)</description>
    <mitre>
      <id>T1053</id>
      <id>T1053.005</id>
      <id>S0111</id>
    </mitre>
    <info type="link">https://github.com/SigmaHQ/sigma/blob/c56cd2dfff6343f3694ef4fd606a305415599737/rules/windows/process_creation/win_susp_schtask_creation.yml</info>
    <info type="text">Detects the creation of scheduled tasks in user session </info>
    <info type="text">(old win010). </info>
    <options>no_full_log</options>
    <group>attack.execution, attack.persistence, attack.privilege_escalation, car.2013-08-001, needs, metron, win010,</group>
  </rule>
  
  <rule id="100103" level="6"> <!-- дублирование правила для Sysmon -->
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image">\\schtasks.exe$</field>
    <field name="win.eventdata.commandLine"> /create </field>
    <description>Scheduled Task Creation by $(win.eventdata.parentImage)</description>
    <mitre>
      <id>T1053</id>
      <id>T1053.005</id>
      <id>S0111</id>
    </mitre>
    <info type="link">https://github.com/SigmaHQ/sigma/blob/c56cd2dfff6343f3694ef4fd606a305415599737/rules/windows/process_creation/win_susp_schtask_creation.yml</info>
    <info type="text">Detects the creation of scheduled tasks in user session </info>
    <info type="text">(old win010). </info>
    <options>no_full_log</options>
    <group>attack.execution, attack.persistence, attack.privilege_escalation, car.2013-08-001, needs, metron, win010,</group>
  </rule>
  
  <!--TO DO: возможно нужны исключения к 100102
  <rule id="100103" level="3">
    <if_sid>100102</if_sid> 
    <field name="win.eventdata.targetDomainName">NT AUTHORITY</field> 
    <description>Legitimate NT AUTHORITY\SYSTEM</description>
  </rule>
  -->

  <rule id="100104" level="3">
    <if_sid>100100, 61603</if_sid>
    <field name="win.eventdata.commandLine">tasklist|systeminfo|whoami|nbtstat|qprocess|nslookup|hostname|(net \s*start)|(net1 \s*start)|(net1 \s*group \s*/domain)|(net1 \s*group \s*"domain \s*admins" \s*/domain)|(net1 \s*group \s*"Exchange \s*Trusted \s*Subsystem" \s*/domain)|(net1 \s*accounts \s*/domain)|(net1 \s*user \s*net \s*localgroup \s*administrators)|(netstat \s*-an)|(net \s*time)</field>
    <description>Net Command Use $(win.eventdata.commandLine)</description>
    <info type="link">https://github.com/SigmaHQ/sigma/blob/c56cd2dfff6343f3694ef4fd606a305415599737/rules/windows/process_creation/win_susp_commands_recon_activity.yml</info>
    <group>attack.discovery, car.2016-03-001, metron, win012,</group>
  </rule>

  <rule id="100105" level="6" frequency="3" timeframe="15">
    <if_matched_sid>100104</if_matched_sid>
    <!-- <same_user />  На данный момент сгруппировал по полю user -->
    <description>Reconnaissance Activity with Net Command</description>
    <info type="text">Detects a set of commands often used in recon stages by different attack groups </info>
    <info type="link">https://github.com/SigmaHQ/sigma/blob/c56cd2dfff6343f3694ef4fd606a305415599737/rules/windows/process_creation/win_susp_commands_recon_activity.yml</info>
    <mitre>
      <id>T1087</id>
      <id>T1082</id>
    </mitre>
    <group>attack.discovery, car.2016-03-001, metron, win012,</group>
  </rule>

  <rule id="100106" level="3">
    <if_group>process_creation_4688</if_group>
    <field name="win.eventdata.newProcessName">\\rar.exe$</field>
    <field name="win.eventdata.commandLine"> \s*a \s*</field>
    <description>Data Compressed - rar.exe</description>
    <info type="text">An adversary may compress data (e.g., sensitive documents) that is collected prior to exfiltration in order to make it portable and minimize the amount of data sent over the network </info>
    <info type="link">https://github.com/SigmaHQ/sigma/blob/a08571be9107d1c0e216400ffbb89c394fcd2570/rules/windows/process_creation/win_data_compressed_with_rar.yml</info>
    <mitre>
      <id>T1002</id> <!-- an old one -->
      <id>T1160</id>
      <id>T1560.001</id>
    </mitre>
    <group>attack.exfiltration, attack.collection, metron, win013,</group>
  </rule>
  
  <rule id="100107" level="3"> <!-- дублирование правила для Sysmon -->
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image">\\rar.exe$</field>
    <field name="win.eventdata.commandLine"> \s*a \s*</field>
    <description>Data Compressed - rar.exe</description>
    <info type="text">An adversary may compress data (e.g., sensitive documents) that is collected prior to exfiltration in order to make it portable and minimize the amount of data sent over the network </info>
    <info type="link">https://github.com/SigmaHQ/sigma/blob/a08571be9107d1c0e216400ffbb89c394fcd2570/rules/windows/process_creation/win_data_compressed_with_rar.yml</info>
    <mitre>
      <id>T1002</id> <!-- an old one -->
      <id>T1160</id>
      <id>T1560.001</id>
    </mitre>
    <group>attack.exfiltration, attack.collection, metron, win013,</group>
  </rule>

  <rule id="100108" level="3">
    <if_group>process_creation_4688</if_group>
    <field name="win.eventdata.newProcessName">\\tshark.exe$|\\windump.exe$</field>
    <description>Network Sniffing $(win.eventdata.newProcessName)</description>
    <info type="text">Network sniffing refers to using the network interface on a system to monitor or capture information sent over a wired or wireless connection. </info>
    <info type="text">An adversary may place a network interface into promiscuous mode to passively access data in transit over the network, or use span ports to capture a larger amount of data. </info>
    <info type="link">https://github.com/SigmaHQ/sigma/blob/a08571be9107d1c0e216400ffbb89c394fcd2570/rules/windows/process_creation/win_network_sniffing.yml</info>
    <mitre>
      <id>T1040</id>
    </mitre>
    <group>attack.credential_access, attack.discovery, metron, win014,</group>
  </rule>
  
  <rule id="100109" level="3"> <!-- дублирование правила для Sysmon -->
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image">\\tshark.exe$|\\windump.exe</field>
    <description>Network Sniffing $(win.eventdata.image)</description>
    <info type="text">Network sniffing refers to using the network interface on a system to monitor or capture information sent over a wired or wireless connection. </info>
    <info type="text">An adversary may place a network interface into promiscuous mode to passively access data in transit over the network, or use span ports to capture a larger amount of data. </info>
