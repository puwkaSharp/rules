  <rule id="100604" level="2">
    <if_group>win_event_file_creation</if_group>
    <field name="win.eventdata.targetFilename">\\lsass\.\.\.\.\..dmp$</field>
    <description>Sysmon - Event 11: FileCreate by $(data.win.eventdata.image)</description>
