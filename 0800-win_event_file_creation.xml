<!-- Andrew. -->
<!-- Перезаписываю два правила сисмон 11, для того чтобы добавить полезную нам группу win_event_file_creation. -->
<group name="windows,sysmon,"> 
  <rule id="61613" level="1" overwrite="yes">
    <if_sid>61600</if_sid>
    <field name="win.system.eventID">^11$</field>
    <description>Sysmon - Event 11: FileCreate by $(win.eventdata.sourceImage)</description>
    <group>sysmon_event_11,win_event_file_creation,</group>
  </rule>
</group>

<group name="sysmon,">
  <rule id="185009" level="1" overwrite="yes">
    <if_sid>18100</if_sid>
    <match>Microsoft-Windows-Sysmon/Operational: INFORMATION(11)</match>
    <description>Sysmon - Event 11</description>
    <group>sysmon_event_11,win_event_file_creation,</group>
  </rule>
</group>

<!-- id 100500 свободно -->

<group name="windows,sysmon_event_11,win_event_file_creation,"> <!-- я думаю так можно дальше и использовать эту группу -->
  
  <!-- Анвар залез сюда чтобы вкинуть правило 083 -->
  <rule id="100601" level="14">
   <if_group>win_event_file_creation</if_group>
   <field name="win.eventdata.targetFilename">\\Microsoft\\Word\\Startup</field>
   <field name="win.eventdata.targetFilename">.wll$</field>
   <description>Microsoft Office Word Add-In Loading</description>
   <info type="text">Detects add-ins that load when Microsoft Word starts. </info>
   <info type="link">https://github.com/SigmaHQ/sigma/blob/a08571be9107d1c0e216400ffbb89c394fcd2570/rules/windows/file_event/sysmon_office_persistence.yml</info>
   <mitre>
     <id>T1137</id> <!-- an old one -->
     <id>T1137.006</id>
   </mitre>
   <group>attack.persistence, metron, win083,</group>
  </rule>
  
  <rule id="100602" level="14">
   <if_group>win_event_file_creation</if_group>
   <field name="win.eventdata.targetFilename">\\Microsoft\\Excel\\Startup</field>
   <field name="win.eventdata.targetFilename">.xll$</field>
   <description>Microsoft Office Excel Add-In Loading</description>
   <info type="text">Detects add-ins that load when Microsoft Excel starts. </info>
   <info type="link">https://github.com/SigmaHQ/sigma/blob/a08571be9107d1c0e216400ffbb89c394fcd2570/rules/windows/file_event/sysmon_office_persistence.yml</info>
   <mitre>
     <id>T1137</id> <!-- an old one -->
     <id>T1137.006</id>
   </mitre>
   <group>attack.persistence, metron, win083,</group>
  </rule>
  
  <rule id="100603" level="14">
   <if_group>win_event_file_creation</if_group>
   <field name="win.eventdata.targetFilename">\\Microsoft\\Addins</field>
   <field name="win.eventdata.targetFilename">.xlam$|.xla$</field>
   <description>Microsoft Office Add-In Loading</description>
   <info type="text">Detects add-ins that load when Microsoft Word or Excel starts. </info>
   <info type="link">https://github.com/SigmaHQ/sigma/blob/a08571be9107d1c0e216400ffbb89c394fcd2570/rules/windows/file_event/sysmon_office_persistence.yml</info>
   <mitre>
     <id>T1137</id> <!-- an old one -->
     <id>T1137.006</id>
   </mitre>
   <group>attack.persistence, metron, win083,</group>
  </rule>
